# Copy to .env and fill in. NEVER commit the real .env (see .gitignore).

# --- Claude API (required) ---
ANTHROPIC_API_KEY=

# Model config. Default to Opus 4.8 for judgment; changing this is a deliberate
# cost/quality decision, not a default downgrade.
TRIAGE_MODEL=claude-opus-4-8
# EXTRACTION_MODEL=claude-haiku-4-5   # optional cheaper model for simple extraction
# JUDGE_MODEL=claude-opus-4-8

# --- External intelligence APIs ---
# Confirm each provider's current free-tier limits before wiring it up.
VIRUSTOTAL_API_KEY=
URLSCAN_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
ABUSEIPDB_API_KEY=          # advanced / optional

# --- Observability (Week 3) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
