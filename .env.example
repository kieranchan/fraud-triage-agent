# Copy to .env and fill in. NEVER commit the real .env (see .gitignore).

# --- LLM via CPA (CLIProxyAPI) — OpenAI-compatible gateway (required) ---
# grok-4.5 works through /v1/chat/completions. Switch models by changing LLM_MODEL
# (the proxy also exposes claude-* and gpt-5.x). Key is sent as Authorization: Bearer.
LLM_BASE_URL=https://your-cpa-domain/v1
LLM_API_KEY=
LLM_MODEL=grok-4.5

# --- Direct Anthropic (optional / legacy) ---
# Only if you also want to call native Claude directly (NOT via the CPA).
# ANTHROPIC_API_KEY=

# --- External intelligence APIs ---
# Confirm each provider's current free-tier limits before wiring it up.
VIRUSTOTAL_API_KEY=
URLSCAN_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
ABUSEIPDB_API_KEY=          # advanced / optional

# --- Observability (Week 3) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
